# Copy this file to .env.vps before running docker compose
POSTGRES_PASSWORD=change-this-strong-db-password

NODE_ENV=production
DATABASE_URL=postgresql://ops:change-this-strong-db-password@db:5432/ops_center
AUTH_SECRET=change-this-with-a-long-random-secret
APP_URL=https://bittax.it

BOOTSTRAP_ADMIN_EMAIL=admin@bittax.it
BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
BOOTSTRAP_ADMIN_NAME=Administrator
DEFAULT_TIMEZONE=Europe/Rome
DEFAULT_LOCALE=it-IT
